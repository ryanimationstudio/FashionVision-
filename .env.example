# Supabase Configuration
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Supabase Table Names
SUPABASE_UPLOADS_TABLE=uploads
SUPABASE_SCHEDULED_PINS_TABLE=scheduled_pins

# Supabase Storage Bucket Name
SUPABASE_STORAGE_BUCKET=fashion-images

# Flask / JWT Secret Key (generate a random string)
SECRET_KEY=change-this-to-a-secure-random-string
JWT_SECRET=change-this-to-a-secure-random-string

# Client URL (for CORS)
CLIENT_URL=http://localhost:3000

# Gemini API Key (required for /api/chat/consult and rich AI text generation)
GEMINI_API_KEY=your-gemini-api-key

# Hugging Face token (recommended for faster model downloads and higher rate limits)
HF_TOKEN=your-huggingface-token

# Optional: reduce startup model-loading noise
TRANSFORMERS_VERBOSITY=error
HF_HUB_DISABLE_PROGRESS_BARS=1

# Flask-Limiter storage backend (use Redis in production)
# Examples:
# RATELIMIT_STORAGE_URI=memory://
# RATELIMIT_STORAGE_URI=redis://localhost:6379/0
RATELIMIT_STORAGE_URI=memory://
